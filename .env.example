# ─────────────────────────────────────────────────────────────
# Akses privat (login Google + allowlist email). Jika AUTH_GOOGLE_ID
# kosong, gerbang login NONAKTIF (aplikasi terbuka).
# ─────────────────────────────────────────────────────────────
# Buat secret acak: jalankan `openssl rand -base64 32`
AUTH_SECRET=
# Kredensial OAuth dari Google Cloud Console (APIs & Services → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Email yang diizinkan masuk (pisahkan dengan koma). Mis. nama@gmail.com
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────
# Fitur "Ulasan AI" (opsional). Tanpa kunci, dipakai ringkasan non-AI.
# ─────────────────────────────────────────────────────────────
# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# DeepSeek (kompatibel OpenAI) — https://platform.deepseek.com/
DEEPSEEK_API_KEY=
